{
  "name": "creator_profile_builder",
  "version": "1.0",
  "purpose": "从最多50条创作者作品元数据生成可供选题匹配的结构化画像",
  "input": {
    "creator_id": "string",
    "platform": "string",
    "explicit_profile": "object",
    "history": "array<work_metadata>, maxItems=50",
    "llm_output": "optional string, only for replay/test",
    "allow_rule_fallback": "boolean, default false"
  },
  "output_required": [
    "creator_identity_tags",
    "content_positioning",
    "content_format",
    "creator_size",
    "domain_profile",
    "audience_profile",
    "evidence_summary",
    "confidence"
  ],
  "unknown_policy": "evidence不足时使用unknown或null，不猜测粉丝数、受众和形式"
}
